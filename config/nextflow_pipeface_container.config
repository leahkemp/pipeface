
params.vep_db = ''
params.revel_db = ''
params.gnomad_db = ''
params.clinvar_db = ''
params.cadd_snv_db = ''
params.cadd_indel_db = ''
params.cadd_sv_db = ''
params.spliceai_snv_db = ''
params.spliceai_indel_db = ''
params.alphamissense_db = ''
params.clair3_config = "${projectDir}/config/clair3_glnexus.yml"
params.publish_mode = 'copy'

singularity {

    enabled = true
    pullTimeout = '1h'
    cacheDir = ''

}

process {

    executor = ''
    project = ''
    storage = ''
    maxForks = 50

    withName: 'scrape_settings' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '20m'
    }

    withName: 'merge_runs' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '6h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'minimap2' {
        queue = ''
        cpus = '16'
        memory = '64GB'
        time = '14h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'minimod' {
        queue = ''
        cpus = '8'
        memory = '32GB'
        disk = '20GB'
        time = '8h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'mosdepth' {
        queue = ''
        cpus = '8'
        memory = '32GB'
        time = '2h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'clair3_pre_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '30m'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'clair3|clair3_haploid_aware' {
        queue = ''
        cpus = '32'
        memory = '128GB'
        disk = '20GB'
        time = '16h'
        container = 'hkubal/clair3:v1.0.9'
    }

    withName: 'clair3_post_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        disk = '30GB'
        time = '2h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'deepvariant_dry_run' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '20m'
        container = 'google/deepvariant:1.8.0-gpu'
    }

    withName: 'deepvariant_make_examples' {
        queue = ''
        cpus = '104'
        memory = '500GB'
        disk = '10GB'
        time = '2h'
        container = 'google/deepvariant:1.8.0-gpu'
    }

    withName: 'deepvariant_call_variants' {
        queue = ''
        cpus = '12'
        gpus = '1'
        memory = '96GB'
        disk = '10GB'
        time = '2h'
        container = 'google/deepvariant:1.8.0-gpu'
    }

    withName: 'deepvariant_post_processing' {
        queue = ''
        cpus = '14'
        memory = '128GB'
        disk = '30GB'
        time = '3h'
        container = 'google/deepvariant:1.8.0-gpu'
    }

    withName: 'filter_ref_call' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'split_multiallele|split_multiallele_family' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        disk = '10GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'longtr_pre_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'longtr' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '4h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'concat_tr_vcf' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'vep_snp_indel|vep_sv' {
        queue = ''
        cpus = '32'
        memory = '128GB'
        time = '24h'
        container = 'ensemblorg/ensembl-vep:release_112.0'
    }

    withName: 'whatshap_phase' {
        queue = ''
        cpus = '4'
        memory = '16GB'
        time = '24h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'whatshap_phase_family' {
        queue = ''
        cpus = '4'
        memory = '16GB'
        time = '36h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'whatshap_haplotag' {
        queue = ''
        cpus = '4'
        memory = '16GB'
        time = '10h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'deeptrio_dry_run' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '20m'
        container = 'google/deepvariant:deeptrio-1.8.0-gpu'
    }

    withName: 'deeptrio_make_examples' {
        queue = ''
        cpus = '104'
        memory = '500GB'
        disk = '10GB'
        time = '12h'
        container = 'google/deepvariant:deeptrio-1.8.0-gpu'
    }

    withName: 'deeptrio_call_variants' {
        queue = ''
        cpus = '12'
        gpus = '1'
        memory = '96GB'
        disk = '1GB'
        time = '6h'
        container = 'google/deepvariant:deeptrio-1.8.0-gpu'
    }

    withName: 'deeptrio_postprocessing' {
        queue = ''
        cpus = '14'
        memory = '128GB'
        disk = '10GB'
        time = '3h'
        container = 'google/deepvariant:deeptrio-1.8.0-gpu'
    }

    withName: 'somalier_extract|somalier_relate' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'glnexus_pre_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'glnexus' {
        queue = ''
        cpus = '1'
        memory = '96GB'
        time = '2h'
        container = 'ghcr.io/dnanexus-rnd/glnexus:v1.4.3'
    }

    withName: 'glnexus_post_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '30m'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'sniffles' {
        queue = ''
        cpus = '4'
        memory = '16GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'cutesv' {
        queue = ''
        cpus = '8'
        memory = '32GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.4'
    }

    withName: 'jasmine' {
        queue = ''
        cpus = '8'
        memory = '32GB'
        time = '12h'
        container = 'leahkemp/pipeface:0.0.4'
    }

}

