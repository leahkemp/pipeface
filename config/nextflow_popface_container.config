
params.vep_db = ''
params.revel_db = ''
params.gnomad_db = ''
params.clinvar_db = ''
params.cadd_snv_db = ''
params.cadd_indel_db = ''
params.cadd_sv_db = ''
params.spliceai_snv_db = ''
params.spliceai_indel_db = ''
params.alphamissense_db = ''
params.clair3_config = "${projectDir}/config/clair3_glnexus.yml"
params.publish_mode = 'copy'

singularity {

    enabled = true
    pullTimeout = '1h'
    cacheDir = ''

}

process {

    executor = ''
    project = ''
    storage = ''
    maxForks = 250

    withName: 'scrape_settings' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '20m'
    }

    withName: 'glnexus_pre_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'glnexus' {
        queue = ''
        cpus = '43'
        memory = '190GB'
        time = '12h'
        container = 'ghcr.io/dnanexus-rnd/glnexus:v1.4.3'
    }

    withName: 'glnexus_post_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'split_multiallele' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        disk = '10GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'split_vcf' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'whatshap_phase' {
        queue = ''
        cpus = '4'
        memory = '16GB'
        time = '10h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'merge_vcf' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '30m'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'split_sv_vcfs' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'jasmine' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '48h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'somalier' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'longtr_pre_processing' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '1h'
    }

    withName: 'longtr' {
        queue = ''
        cpus = '1'
        memory = '32GB'
        time = '24h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'concat_sv_vcf|concat_tr_vcf' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        disk = '10GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.5'
    }

    withName: 'vep_snp_indel|vep_sv' {
        queue = ''
        cpus = '32'
        memory = '128GB'
        time = '24h'
        container = 'ensemblorg/ensembl-vep:release_112.0'
    }

}

