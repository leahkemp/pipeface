
params.vep_db = ''
params.revel_db = ''
params.gnomad_db = ''
params.clinvar_db = ''
params.cadd_snv_db = ''
params.cadd_indel_db = ''
params.cadd_sv_db = ''
params.spliceai_snv_db = ''
params.spliceai_indel_db = ''
params.alphamissense_db = ''

singularity {

    enabled = true
    pullTimeout = '1h'
    cacheDir = ''

}

process {

    executor = ''
    project = ''
    storage = ''

    withName: 'scrape_settings' {
        queue = ''
        cpus = '1'
        memory = '4GB'
        time = '20m'
    }

    withName: 'glnexus' {
        queue = 'normal'
        cpus = '43'
        memory = '190GB'
        time = '12h'
        container = 'ghcr.io/dnanexus-rnd/glnexus:v1.4.3'
    }

    withName: 'glnexus_post_processing' {
        queue = 'normal'
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.2'
    }

    withName: 'split_multiallele' {
        queue = 'normal'
        cpus = '1'
        memory = '4GB'
        disk = '10GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.2'
    }

    withName: 'split_vcf' {
        queue = 'normal'
        cpus = '1'
        memory = '4GB'
        time = '3h'
        container = 'leahkemp/pipeface:0.0.2'
    }

    withName: 'whatshap_phase' {
        queue = 'normal'
        cpus = '4'
        memory = '16GB'
        time = '10h'
        container = 'leahkemp/pipeface:0.0.2'
    }

    withName: 'merge_vcf' {
        queue = 'normal'
        cpus = '1'
        memory = '4GB'
        time = '30m'
        container = 'leahkemp/pipeface:0.0.2'
    }

    withName: 'somalier' {
        queue = 'normal'
        cpus = '1'
        memory = '4GB'
        time = '1h'
        container = 'leahkemp/pipeface:0.0.2'
    }

    withName: 'vep_snp_indel' {
        queue = 'normal'
        cpus = '32'
        memory = '128GB'
        time = '24h'
        container = 'leahkemp/pipeface:0.0.2'
    }

}

